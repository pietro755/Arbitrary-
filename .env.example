# Sui Arbitrage Bot Environment Configuration

# Sui RPC endpoint (mainnet)
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Your wallet mnemonic or private key (KEEP SECRET - never commit this file)
# Use MNEMONIC for a BIP39 seed phrase
WALLET_MNEMONIC=

# Minimum profit threshold in USD to execute a trade
MIN_PROFIT_USD=1.0

# Maximum trade size in SUI
MAX_TRADE_SIZE_SUI=100

# Poll interval in milliseconds
POLL_INTERVAL_MS=3000

# Slippage tolerance (0.005 = 0.5%)
SLIPPAGE_TOLERANCE=0.005

# Gas budget in MIST (1 SUI = 1,000,000,000 MIST)
GAS_BUDGET=50000000

# Enable dry-run mode (true = simulate only, no real transactions)
DRY_RUN=true

# Log level: debug | info | warn | error
LOG_LEVEL=info
